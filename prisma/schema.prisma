generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url = env("DATABASE_URL")
}

model ScrapedItem {
  id        String   @id @default(cuid())
  title     String
  url       String   @unique
  source    String?
  content   String?
  fetchedAt DateTime @default(now())
}

model WorkerStatus {
  name      String   @id
  lastRun   DateTime
  error     String?
}
