generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  email String @unique
  password  String
  role UserRole @default(USER)
  hasFullAccess Boolean @default(false)

  name      String?
  isEmailVerified Boolean @default(false)
  phone String?
  currentDeviceId String?
  lastDeviceFingerprint String?
  googleId String? @unique
  createdVia String @default("email")
  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  // Relations
  sessions  Session[]
  profiles  Profile[]
  userLogs  UserLog[]
  pageActivities PageActivity[]

}

model Session {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  token String @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  // Relations
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Profile {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  userId String @unique
  bio       String?
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ScrapedItem {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  title String
  url       String   @unique
  source    String?
  content   String?
  fetchedAt DateTime @default(now())
}

model WorkerStatus {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  name String @unique
  lastRun   DateTime

  error     String?
}

model UserLog {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  userId String
  action             String
  ip                 String?
  deviceFingerprint  String?
  timestamp          DateTime @default(now())

  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_logs")
}

model PageActivity {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  userId String
  pagePath String
  durationMs Int
  createdAt DateTime @default(now())
  ip String?
  deviceFingerprint String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([pagePath, createdAt])
  @@map("page_activities")
}

enum UserRole {
  USER
  ADMIN
}

